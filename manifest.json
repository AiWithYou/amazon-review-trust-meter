{
  "manifest_version": 3,
  "name": "Amazon レビュー注意度メーター",
  "version": "1.2.1",
  "description": "Amazon.co.jpの商品情報、評価分布、表示レビューをローカル分析し、購入前の注意度を表示します。",
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.co.jp/dp/*",
        "https://www.amazon.co.jp/*/dp/*",
        "https://www.amazon.co.jp/gp/product/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
