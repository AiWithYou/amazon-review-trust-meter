{
  "manifest_version": 3,
  "name": "Amazon レビュー注意度メーター",
  "version": "2.0.0",
  "description": "Amazon.co.jpの星分布、表示レビュー、投稿時系列をローカル複合分析し、注意度と判定確度を表示します。",
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.co.jp/dp/*",
        "https://www.amazon.co.jp/*/dp/*",
        "https://www.amazon.co.jp/gp/product/*"
      ],
      "js": [
        "scoring-base.js",
        "scoring-features.js",
        "scoring.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
